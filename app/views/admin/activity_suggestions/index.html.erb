<% content_for :head do %>
  <title>Sugestões do Dia · Admin</title>
<% end %>

<div class="dash-outer" style="max-width:860px; margin:0 auto;">

  <%= link_to admin_root_path,
        style: "display:inline-flex; align-items:center; gap:6px; font-family:'Plus Jakarta Sans',sans-serif;
                font-size:0.82rem; font-weight:600; color:var(--ink-soft); text-decoration:none; margin-bottom:1.25rem;" do %>
    ← Painel Admin
  <% end %>

  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:1.5rem; flex-wrap:wrap;">
    <div style="display:flex; align-items:center; gap:10px;">
      <h1 style="font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:700; color:var(--ink); margin:0;">
        Sugestões do Dia
      </h1>
      <span style="font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.1em;
                   background:var(--action); color:var(--surface); padding:3px 10px; border-radius:20px; text-transform:uppercase;">
        ✨ Agente
      </span>
    </div>
    <%= button_to generate_now_admin_activity_suggestions_path, method: :post,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--surface); background:var(--brand-deep); padding:9px 20px; border-radius:10px; border:none; cursor:pointer; white-space:nowrap;" do %>
      🔎 Gerar sugestão agora
    <% end %>
  </div>

  <% if flash[:notice] %>
    <div style="background:var(--brand-tint); border:1.5px solid var(--brand-bright); border-radius:10px; padding:12px 16px; margin-bottom:18px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--brand-deep);">
      <%= flash[:notice] %>
    </div>
  <% end %>
  <% if flash[:alert] %>
    <div style="background:var(--error-tint); border:1.5px solid var(--error-border); border-radius:10px; padding:12px 16px; margin-bottom:18px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--error-deep);">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if @suggestions.empty? %>
    <div style="background:var(--surface); border:1px solid var(--line); border-radius:20px; padding:56px 32px; text-align:center;">
      <div style="width:64px; height:64px; background:var(--line-soft); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:1.8rem;">🔎</div>
      <div style="font-family:'Raleway',sans-serif; font-size:1.05rem; font-weight:700; color:var(--ink); margin-bottom:8px;">
        Nenhuma sugestão pendente
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-faint); margin-bottom:24px; line-height:1.6; max-width:380px; margin-left:auto; margin-right:auto;">
        Clique em "Gerar sugestão agora" e o agente vai consultar o catálogo, as avaliações e o desempenho dos alunos antes de propor um tema.
      </div>
      <%= button_to generate_now_admin_activity_suggestions_path, method: :post,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; color:var(--surface); background:var(--brand); padding:13px 32px; border-radius:12px; border:none; cursor:pointer;" do %>
        🔎 Gerar agora
      <% end %>
    </div>

  <% else %>
    <div style="display:flex; flex-direction:column; gap:14px;">
      <% @suggestions.each do |s| %>
        <div style="background:var(--surface); border:1px solid var(--line); border-radius:16px; padding:24px;">
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
            <span style="font-family:'DM Mono',monospace; font-size:0.7rem; font-weight:700; letter-spacing:0.08em;
                         background:var(--brand-tint); color:var(--brand-deep); padding:3px 10px; border-radius:20px;">
              <%= s.level_hint %>
            </span>
            <span style="font-family:'Raleway',sans-serif; font-size:1.05rem; font-weight:700; color:var(--ink);">
              <%= s.theme %>
            </span>
          </div>

          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-soft); line-height:1.6; margin-bottom:18px; border-left:3px solid var(--brand-bright); padding-left:12px;">
            <strong style="color:var(--ink);">Por quê:</strong> <%= s.rationale %>
          </div>

          <div style="display:flex; gap:10px;">
            <%= button_to approve_admin_activity_suggestion_path(s), method: :post,
                  style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--surface); background:var(--action); padding:10px 20px; border-radius:10px; border:none; cursor:pointer;" do %>
              ✨ Gerar atividade
            <% end %>
            <%= button_to reject_admin_activity_suggestion_path(s), method: :post,
                  style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600; color:var(--ink-soft); background:var(--surface); border:1.5px solid var(--line); padding:10px 20px; border-radius:10px; cursor:pointer;" do %>
              Descartar
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
